<?xml version="1.0" encoding="UTF-8"?>

<JUCERPROJECT id="zS4Ip5" name="BlockShuffler" companyName="gobi10k" version="1.0.0"
              projectType="audioplug"
              pluginName="BlockShuffler"
              pluginDesc="Block-based arrangement randomizer"
              pluginManufacturer="gobi10k"
              pluginManufacturerCode="Gb1k"
              pluginCode="BkSh"
              pluginFormats="buildVST3,buildStandalone"
              useAppConfig="0"
              addUsingNamespaceToJuceHeader="0"
              jucerFormatVersion="1">

  <MAINGROUP id="NRSShe" name="BlockShuffler">

    <GROUP id="{E1000001-0000-0000-0000-000000000001}" name="Plugin">
      <FILE id="PP0001" name="PluginProcessor.h"   compile="0" resource="0" file="Source/PluginProcessor.h"/>
