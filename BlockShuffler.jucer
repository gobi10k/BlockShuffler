      <FILE id="AU0008" name="ExportRenderer.cpp"      compile="1" resource="0" file="Source/Audio/ExportRenderer.cpp"/>
    </GROUP>

    <GROUP id="{E1000004-0000-0000-0000-000000000004}" name="UI">
